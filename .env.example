NODE_ENV=development
PORT=3000

JWT_SECRET=your_super_secret_key
TOKEN_EXPIRATION=15m
REFRESH_SECRET=your_refresh_secret

# Password reset (backend)
RESET_TOKEN_SECRET=your_reset_secret_here
RESET_TOKEN_TTL_MINUTES=15

# Database
# The backend uses `MONGO_URI` (Render-friendly). `DB_URI` is accepted as an alias.
MONGO_URI=mongodb://mongo:27017/gymdb
DB_URI=mongodb://mongo:27017/gymdb

# Redis (optional)
REDIS_URI=redis://redis:6379

# CORS (backend)
# Comma-separated list of allowed origins, e.g.:
# CORS_ORIGIN=http://localhost:5173,https://tu-frontend.onrender.com
CORS_ORIGIN=http://localhost:5173

# Frontend (Render Static Site)
# VITE_API_URL=https://tu-backend.onrender.com
VITE_API_URL=http://localhost:3000


VITE_APP_ENV=development